# Cloudflare `_headers` file. Picked up by `@sveltejs/adapter-cloudflare`
# from the project root and merged into `.svelte-kit/cloudflare/_headers`
# at build time (the adapter appends its own immutable-asset caching
# block below these rules).
#
# These headers are applied by the ASSETS binding (see wrangler.jsonc)
# *before* the SvelteKit worker runs — this is the only way to attach
# response headers to prerendered static pages, because the `handle`
# hook in src/hooks.server.ts cannot reach them.

# Security headers for every static/prerendered response. The dynamic
# counterpart lives in src/hooks.server.ts — keep the two in sync. CSP
# here intentionally mirrors the dynamic one; Turnstile is only loaded
# on /contact (dynamic) but allowing it in the static directives costs
# nothing and avoids divergence.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Access-Control-Expose-Headers: Link

# Agent discovery: Link header on the homepage (RFC 8288) pointing at the
# sitemap, the RSS feed as a feed alternate, and the RFC 9727 API
# catalog. Agents that fetch `/` can follow these relations without
# guessing well-known URLs.
/
  Link: </sitemap.xml>; rel="sitemap", </rss.xml>; rel="alternate"; type="application/rss+xml"; title="RSS feed", </.well-known/api-catalog>; rel="api-catalog"; type="application/linkset+json"

# Per-post markdown alternate. `:slug` is substituted by Workers Assets
# into both the match path and the header value, so each blog post
# advertises its matching /blog/<slug>.md representation.
/blog/:slug/
  Link: </blog/:slug.md>; rel="alternate"; type="text/markdown"
/blog/:slug
  Link: </blog/:slug.md>; rel="alternate"; type="text/markdown"

# Workers Assets serves .md with `Content-Type: text/markdown` (no
# charset), so browsers fall back to Latin-1 and mangle UTF-8 CJK.
# Override with an explicit charset. The +server.ts handler already
# sets this, but the prerendered file is served by the ASSETS binding
# which applies its own extension-based MIME map.
/blog/:slug.md
  Content-Type: text/markdown; charset=utf-8
